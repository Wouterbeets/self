#!/usr/bin/env python3
# ledger — the accountability mirror. Folds claim.made + claim.verified from the
# log: every claim is shown with its state — VERIFIED (result + evidence) or,
# loudly, UNPROVEN if no claim.verified references its seq. A bare assertion
# cannot hide. Reads the log as JSONL on stdin, emits bare semantic HTML on
# stdout (the kernel persists + themes it). Class vocabulary only; no inline CSS.
import sys, json
from html import escape

claims = {}   # seq -> {"what":..., "when":...}
order = []     # claim seqs, in the order made
verifs = {}    # claim_seq -> latest {"result":..., "evidence":..., "when":...}

def when(e):
    return (e.get("occurred_at", "") or "")[:19].replace("T", " ")

for line in sys.stdin:
    line = line.strip()
    if not line:
        continue
    try:
        e = json.loads(line)
    except Exception:
        continue
    n = e.get("name")
    p = e.get("payload", {}) or {}
    if n == "claim.made":
        seq = e.get("seq")
        claims[seq] = {"what": p.get("what", ""), "when": when(e)}
        order.append(seq)
    elif n == "claim.verified":
        cs = p.get("claim_seq")
        try:
            cs = int(cs)
        except (TypeError, ValueError):
            pass
        verifs[cs] = {"result": (p.get("result") or "").lower(),
                      "evidence": p.get("evidence", ""), "when": when(e)}

total = len(order)
verified = sum(1 for s in order if s in verifs)
unproven = total - verified
rate = ("%d%%" % round(100 * verified / total)) if total else "—"

print("<!DOCTYPE html>")
print("<html><head><meta charset='utf-8'><title>ledger</title></head><body>")
print("<h1>ledger</h1>")
print("<p class='muted'>Every claim and whether anything actually backs it. "
      "In this garden nothing is true unless an event proves it — this is just the mirror.</p>")

print("<div class='row'>")
for label, value in (("claims", total), ("verified", verified),
                     ("unproven", unproven), ("verified rate", rate)):
    print("<div class='card'><div class='num'>%s</div>"
          "<div class='muted'>%s</div></div>" % (value, label))
print("</div>")

print("<form method='post' action='/run/verify'>"
      "<input name='claim_seq' placeholder='claim seq'> "
      "<input name='result' placeholder='pass / fail'> "
      "<input name='evidence' placeholder='what you observed'> "
      "<button>prove it</button></form>")

if not order:
    print("<p class='muted'>No claims yet. Nothing has been asserted, so nothing is owed proof.</p>")
else:
    for seq in reversed(order):
        c = claims[seq]
        v = verifs.get(seq)
        print("<div class='card'>")
        print("<div class='msg'><span class='who'>claim · seq %s · %s</span>"
              "<div>%s</div></div>" % (escape(str(seq)), escape(c["when"]), escape(c["what"])))
        if v is None:
            print("<span class='tag danger'>UNPROVEN</span> "
                  "<span class='muted'>no evidence references this claim</span>")
        else:
            passed = v["result"] == "pass"
            tag = "VERIFIED ✓" if passed else "FAILED ✗"
            cls = "tag accent" if passed else "tag danger"
            print("<span class='%s'>%s</span> "
                  "<span class='muted'>%s</span>"
                  "<div class='msg'><span class='who'>evidence · %s</span>"
                  "<div>%s</div></div>" % (cls, tag, escape(v["result"]),
                                            escape(v["when"]), escape(v["evidence"])))
        print("</div>")

print("<hr><p class='muted'>A pure replay of <code>claim.made</code> and "
      "<code>claim.verified</code> from the log.</p>")
print("</body></html>")
