#!/usr/bin/env python3
"""brain-http — the thin half of a two-piece brain. self spawns this once per
ask; it forwards the ask to a long-running brain server over HTTP and prints
the body straight back onto the kernel's pipe. The intelligence — the model
and its tool loop — lives in examples/brain-http-server, which stays warm
next to the GPU.

    export SELF_BRAIN="$PWD/examples/brain-http"
    export SELF_BRAIN_URL=http://127.0.0.1:8484/run   # the default

The wire is one POST per ask: {ask, prompt, brief, home} in, the exact text
the kernel should read on stdout out. The shim adds nothing else on purpose:
the seam self sees stays a dumb pipe, and everything worth watching happens
in one server process. The server must be able to see SELF_HOME on its own
filesystem (its bash tool runs there), so keep the two on the same machine
or a shared mount.
"""

import json
import os
import sys
import urllib.error
import urllib.request


def main():
    body = json.dumps({
        "ask": os.environ.get("SELF_ASK", "think"),
        "prompt": sys.argv[-1] if len(sys.argv) > 1 else "",
        "brief": sys.stdin.read(),
        "home": os.environ.get("SELF_HOME") or os.getcwd(),
    }).encode()
    url = os.environ.get("SELF_BRAIN_URL", "http://127.0.0.1:8484/run")
    req = urllib.request.Request(url, data=body, headers={"Content-Type": "application/json"})
    # A local model exploring an instance is slow on purpose; the budget lives
    # server-side (BRAIN_MAX_TURNS), so the shim just waits.
    timeout = float(os.environ.get("SELF_BRAIN_TIMEOUT", "3600"))
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            sys.stdout.write(resp.read().decode())
    except urllib.error.HTTPError as e:
        sys.stderr.write("brain server error %d: %s\n" % (e.code, e.read().decode(errors="replace")))
        raise SystemExit(1)
    except OSError as e:
        sys.stderr.write("brain server unreachable at %s: %s\nstart it: examples/brain-http-server\n" % (url, e))
        raise SystemExit(1)


if __name__ == "__main__":
    main()
