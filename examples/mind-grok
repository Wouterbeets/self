#!/usr/bin/env python3
"""mind-grok - a SELF_MIND adapter backed by `grok --single`.

The self kernel expects a mind process to print self event JSONL (or prose).
This adapter forwards the kernel's prompt (which contains all protocol
instructions via mindAnswerContract, thinkPrompt etc.) and brief to the
Grok CLI. The kernel prompt remains the single source of protocol instructions.

Usage:

    export SELF_MIND="$PWD/examples/mind-grok"
    export SELF_GROK_MODEL=...  # optional
    self grow seeds/chat
"""

import os
import subprocess
import sys


def grok_command(prompt):
    cmd = [os.environ.get("SELF_GROK", "grok")]
    # --single takes the kernel prompt value immediately.
    cmd.extend(["--single", prompt])
    model = os.environ.get("SELF_GROK_MODEL", "")
    if model:
        cmd.extend(["--model", model])
    # Flags for reliable non-interactive single-turn use as a mind.
    # --always-approve lets the agent use tools without interactive prompts.
    cmd.extend(["--output-format", "plain", "--always-approve", "--no-alt-screen"])
    return cmd


def run_grok(message, brief):
    # Mirror mind-opencode as closely as possible:
    # - kernel prompt (message) is the primary ask passed to the tool
    # - brief (from our stdin) is delivered to the tool
    #
    # Because grok --single takes its context in the prompt arg (unlike opencode
    # run which uses stdin for the brief), we combine them here. This is the
    # minimal adaptation needed for this tool; no extra instructions are added.
    # The combined string contains *only* what the kernel provided.
    # The agent is still encouraged to explore $SELF_HOME directly.
    full_prompt = (brief.rstrip() + "\n\n" + message).strip() if message else brief
    proc = subprocess.run(
        grok_command(full_prompt),
        input=brief,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        cwd=os.environ.get("SELF_HOME") or None,
    )
    if proc.stderr:
        sys.stderr.write(proc.stderr)
    if proc.returncode != 0:
        raise SystemExit(proc.returncode)
    return proc.stdout.strip()


def main():
    prompt = sys.argv[-1] if len(sys.argv) > 1 else ""
    brief = sys.stdin.read()  # orientation brief — grok (via wrapper) can explore SELF_HOME
    print(run_grok(prompt, brief))


if __name__ == "__main__":
    main()


