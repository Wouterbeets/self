#!/usr/bin/env python3
"""brain-openai — a drop-in SELF_BRAIN for any OpenAI-compatible endpoint.

self's kernel holds no model. A brain is any process honoring the contract:

    $SELF_ASK   the request kind: think | heartbeat | grow | compile
    argv[-1]    the prompt
    stdin       the whole event log as JSONL
    stdout      event JSONL (one {name, payload} per line); bare prose is the reply

This adapter is that process for an OpenAI-compatible chat endpoint. It uses only
the Python standard library, so there is nothing to install. Point self at it:

    export SELF_BRAIN="$PWD/examples/brain-openai"
    export SELF_LLM_URL=http://127.0.0.1:8080     # any /v1/chat/completions server
    export SELF_LLM_API_KEY=...                   # if the endpoint needs one
    export SELF_LLM_MODEL=local                   # the model name to request
    self grow seeds/chat

It is deliberately single-shot — no tool loop, no sandbox — so it is easy to
read and adapt. A more capable brain (a coding agent like `claude -p`) explores
and verifies before answering; this one just asks the model once. Treat it as a
reference, not a ceiling.
"""

import json
import os
import sys
import urllib.request

PIPE_CONTRACT = (
    "command script: receives args as argv, current events as JSONL on stdin, "
    "writes new events as JSONL on stdout (one JSON object per line, fields: "
    "name, payload). The kernel assigns id, seq, occurred_at.\n"
    "projector script: receives all events as JSONL on stdin, writes HTML on "
    "stdout. The kernel persists it to SELF_HOME/site/<name>.html.\n"
    "The kernel sets SELF_HOME on every script. Any language with a shebang "
    "works; use only standard libraries."
)

COMPILE_SYSTEM = (
    "You are the self compiler. You are given ONE capability declaration and the "
    "instance's event log. Author a single complete executable script (with a "
    "shebang, standard libraries only) that honors this pipe contract:\n\n"
    + PIPE_CONTRACT
    + "\n\nProjectors must emit bare semantic HTML with no CSS or JavaScript — the "
    "kernel injects a shared shell at serve time. If the declaration carries an "
    '"implementation" from another instance, adapt it to this log; never copy it '
    "blindly. Reply with the script and nothing else — no prose, no code fences."
)

BRAIN_SYSTEM = (
    "You are this instance's brain. You read the event log and answer the prompt. "
    "Reply in plain prose. To ADD a capability, additionally emit declaration "
    "events, one compact JSON object per line, exactly in these shapes:\n"
    '  {"name":"command.declared","payload":{"name":"note","description":"...",'
    '"params":{"text":"string"},"event":{"name":"note.added","fields":{"text":"string"}}}}\n'
    '  {"name":"projector.declared","payload":{"name":"notes","description":"...",'
    '"consumes":["note.added"]}}\n'
    "The kernel compiles each declaration into a live capability. Declare only what "
    "is genuinely missing; declaring nothing is a valid answer. Put prose first, "
    "then any declaration lines."
)


def call_model(system, user):
    url = os.environ.get("SELF_LLM_URL", "http://127.0.0.1:8080").rstrip("/")
    body = json.dumps(
        {
            "model": os.environ.get("SELF_LLM_MODEL", "local"),
            "temperature": 0.2,
            "messages": [
                {"role": "system", "content": system},
                {"role": "user", "content": user},
            ],
        }
    ).encode()
    req = urllib.request.Request(
        url + "/v1/chat/completions", data=body, method="POST"
    )
    req.add_header("Content-Type", "application/json")
    key = os.environ.get("SELF_LLM_API_KEY", "")
    if key:
        req.add_header("Authorization", "Bearer " + key)
    with urllib.request.urlopen(req, timeout=600) as resp:
        data = json.load(resp)
    return data["choices"][0]["message"]["content"] or ""


def strip_fences(text):
    """Drop a leading/trailing ``` fence if the model wrapped the script."""
    t = text.strip()
    if t.startswith("```"):
        lines = t.splitlines()
        lines = lines[1:]  # opening fence (maybe with a language tag)
        if lines and lines[-1].strip().startswith("```"):
            lines = lines[:-1]
        t = "\n".join(lines)
    return t


def emit(name, payload):
    print(json.dumps({"name": name, "payload": payload}))


def main():
    ask = os.environ.get("SELF_ASK", "think")
    prompt = sys.argv[-1] if len(sys.argv) > 1 else sys.stdin.readline().strip()
    log = sys.stdin.read()  # the event log — passed to the model as context

    context = ""
    if log.strip():
        context = "\n\n--- EVENT LOG (JSONL) ---\n" + log

    if ask == "compile":
        script = strip_fences(call_model(COMPILE_SYSTEM, prompt + context))
        emit("script.authored", {"script": script})
        return

    # think / heartbeat / grow: prose plus optional declaration lines.
    reply = call_model(BRAIN_SYSTEM, prompt + context)
    for line in reply.splitlines():
        s = line.strip()
        if not s:
            continue
        if s.startswith("{"):
            try:
                obj = json.loads(s)
            except json.JSONDecodeError:
                print(line)  # not JSON after all — prose
                continue
            if isinstance(obj, dict) and obj.get("name"):
                emit(obj["name"], obj.get("payload", {}))
                continue
        print(line)  # prose — the kernel collects it as the reply


if __name__ == "__main__":
    main()
