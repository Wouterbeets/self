#!/usr/bin/env python3
"""theater/serve — the projector booth for the theater: a tiny static server
and proxy so the flashy lens can watch a self instance. Python standard
library only, kernel untouched.

    self                     # the instance, serving at :7777
    ./theater/serve          # the theater, at http://127.0.0.1:7788

Three jobs, nothing else:
  GET  /               → theater/index.html (and files beside it)
  ANY  /self/<path>    → proxied to the instance (events, projections, /run),
                         Range passed through — the log is append-only, so a
                         byte-offset tail read is always correct
  POST /think {prompt} → `self think <prompt>` on this machine, JSON back

The theater is a lens, not a surface: it holds no state, appends nothing on
its own, and reads the same log every other surface reads. Delete the
directory and nothing is lost.

Environment:
    THEATER_BIND      bind address              (default 127.0.0.1:7788)
    THEATER_SELF_URL  the instance to watch     (default http://127.0.0.1:7777)
    THEATER_SELF_CLI  the self executable       (default "self"); think runs
                      it with this process's environment, so SELF_HOME and
                      SELF_MIND must point where the instance lives
"""

import json
import os
import subprocess
import sys
import urllib.error
import urllib.request
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer

ROOT = os.path.dirname(os.path.abspath(__file__))
BIND = os.environ.get("THEATER_BIND", "").strip() or "127.0.0.1:7788"
SELF_URL = (os.environ.get("THEATER_SELF_URL", "").strip() or "http://127.0.0.1:7777").rstrip("/")
SELF_CLI = os.environ.get("THEATER_SELF_CLI", "").strip() or "self"

TYPES = {".html": "text/html; charset=utf-8", ".js": "text/javascript",
         ".css": "text/css", ".png": "image/png", ".svg": "image/svg+xml"}


def log(msg):
    sys.stderr.write(msg + "\n")
    sys.stderr.flush()


class Handler(BaseHTTPRequestHandler):
    protocol_version = "HTTP/1.1"

    def reply(self, code, body, ctype="text/plain; charset=utf-8", extra=None):
        if isinstance(body, str):
            body = body.encode()
        self.send_response(code)
        self.send_header("Content-Type", ctype)
        self.send_header("Content-Length", str(len(body)))
        for k, v in (extra or {}).items():
            self.send_header(k, v)
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        if self.path.startswith("/self/"):
            return self.proxy("GET")
        path = self.path.split("?")[0]
        if path in ("", "/"):
            path = "/index.html"
        fp = os.path.normpath(os.path.join(ROOT, path.lstrip("/")))
        if not fp.startswith(ROOT) or not os.path.isfile(fp):
            return self.reply(404, "not found")
        with open(fp, "rb") as f:
            data = f.read()
        self.reply(200, data, TYPES.get(os.path.splitext(fp)[1], "application/octet-stream"))

    def do_POST(self):
        if self.path.startswith("/self/"):
            return self.proxy("POST")
        if self.path.rstrip("/") == "/think":
            return self.think()
        self.reply(404, "not found")

    def body(self):
        return self.rfile.read(int(self.headers.get("Content-Length") or 0))

    def proxy(self, method):
        target = SELF_URL + self.path[len("/self"):]
        req = urllib.request.Request(target, data=self.body() if method == "POST" else None,
                                     method=method)
        for h in ("Range", "Content-Type"):
            if self.headers.get(h):
                req.add_header(h, self.headers[h])
        try:
            with urllib.request.urlopen(req, timeout=60) as resp:
                data = resp.read()
                extra = {}
                if resp.headers.get("Content-Range"):
                    extra["Content-Range"] = resp.headers["Content-Range"]
                self.reply(resp.status, data,
                           resp.headers.get("Content-Type") or "application/octet-stream", extra)
        except urllib.error.HTTPError as e:
            self.reply(e.code, e.read())
        except OSError as e:
            self.reply(502, "instance unreachable at %s: %s — is `self` serving?" % (SELF_URL, e))

    def think(self):
        try:
            prompt = (json.loads(self.body()).get("prompt") or "").strip()
        except ValueError:
            prompt = ""
        if not prompt:
            return self.reply(400, '{"error":"POST /think wants JSON: {\\"prompt\\":\\"…\\"}"}',
                              "application/json")
        log("think: %s" % prompt[:120])
        try:
            p = subprocess.run(SELF_CLI.split() + ["think", prompt],
                               capture_output=True, text=True, timeout=900)
        except FileNotFoundError:
            return self.reply(500, json.dumps({"error": "%r not found — install self or set THEATER_SELF_CLI" % SELF_CLI}),
                              "application/json")
        except subprocess.TimeoutExpired:
            return self.reply(504, '{"error":"the mind took longer than 900s"}', "application/json")
        if p.returncode != 0:
            return self.reply(500, json.dumps({"error": (p.stderr or "self think failed").strip()}),
                              "application/json")
        self.reply(200, p.stdout, "application/json")

    def log_message(self, *args):
        pass


def main():
    host, _, port = BIND.partition(":")
    srv = ThreadingHTTPServer((host, int(port or "7788")), Handler)
    log("theater: http://%s → watching %s (think via %r)" % (BIND, SELF_URL, SELF_CLI))
    srv.serve_forever()


if __name__ == "__main__":
    main()
