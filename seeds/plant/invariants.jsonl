{"name": "a single command.declared is emitted as-is plus a seed.planted receipt", "capability": "plant", "kind": "command", "args": ["{\"name\":\"command.declared\",\"payload\":{\"name\":\"foo\",\"description\":\"d\",\"params\":{},\"event\":{\"name\":\"foo.x\",\"fields\":{}}}}"], "expect_contains": ["command.declared", "foo", "seed.planted"]}
{"name": "unparseable spec → a seed.planted error, nothing emitted", "capability": "plant", "kind": "command", "args": ["not json"], "expect_contains": ["seed.planted", "parse error"]}
{"name": "valid JSON that isn't an event → no events found", "capability": "plant", "kind": "command", "args": ["{\"hello\":\"world\"}"], "expect_contains": ["seed.planted", "no events"]}
{"name": "renders the spec form, the prefilled template, starters, and the garden", "capability": "plant", "kind": "projector", "events": [{"name": "command.declared", "payload": {"name": "foo", "description": "Foo it.", "params": {}, "event": {"name": "foo.x"}}}, {"name": "projector.declared", "payload": {"name": "bar", "description": "Bar view.", "consumes": ["foo.x"]}}, {"name": "seed.planted", "payload": {"seed": "ui", "ok": true, "commands": ["foo"], "projectors": ["bar"], "events_replayed": 0}}], "expect_contains": ["plant a capability", "/run/plant", "note.added", "plant: counter", "foo", "bar"]}
